{
  "name": "@pech/chess-board",
  "version": "1.0.0",
  "description": "Chess board UI library — render and interact with chess positions",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "chess",
    "chessboard",
    "board",
    "ui",
    "render",
    "fen",
    "typescript"
  ],
  "license": "MIT",
  "author": "Eduardo Pech",
  "repository": {
    "type": "git",
    "url": "https://github.com/EduardoPech/chess-board.git"
  },
  "homepage": "https://github.com/EduardoPech/chess-board#readme",
  "bugs": {
    "url": "https://github.com/EduardoPech/chess-board/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
